# Copy to .env and fill in. Never commit real keys.

# --- Ledger pipeline LLM (`scripts/run_pipeline.py --llm …`) ---
# OpenRouter (OpenAI-compatible, key usually starts with sk-or-v1-)
OPENROUTER_API_KEY=
# Optional: model slug on OpenRouter (default: google/gemini-2.0-flash-001)
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Google Gemini direct API (NOT the same as OpenRouter — key often starts with AIza)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Anthropic Claude
# ANTHROPIC_API_KEY=

# Optional: OpenRouter attribution headers
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=Axiom Ledger
